# ──────────────────────────────────────────────
# IoT Weather System - Environment Variables
# ──────────────────────────────────────────────

# Backend
NODE_ENV=development
PORT=3001
BACKEND_URL=http://localhost:3001

# Database (Supabase PostgreSQL)
# Get this from Supabase > Settings > Database > Connection string (URI)
# Format: postgresql://<user>:<password>@<host>:<port>/<database>?schema=public
DATABASE_URL=postgresql://postgres:your-supabase-password@db.xxxxxxxxxxxxxx.supabase.co:5432/postgres?schema=public

# MQTT (HiveMQ Cloud: mqtts://<cluster-id>.s1.eu.hivemq.cloud:8883)
MQTT_BROKER_URL=mqtts://your-cluster-id.s1.eu.hivemq.cloud:8883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=weather-backend

# OpenWeatherMap API (provides temperature, humidity, pressure)
OPENWEATHER_API_KEY=your_openweather_api_key_here
OPENWEATHER_LAT=-0.0797
OPENWEATHER_LON=34.7316

# Frontend MQTT (used by Vite at build time — passed via docker-compose build.args)
VITE_MQTT_BROKER_URL=wss://your-cluster-id.s1.eu.hivemq.cloud:8884/mqtt
VITE_MQTT_USERNAME=your-mqtt-username
VITE_MQTT_PASSWORD=your-mqtt-password
VITE_MQTT_CLIENT_PREFIX=dashboard

# ESP32 Device
ESP32_DEVICE_ID=station-001
