# ──────────────────────────────────────────────
# IoT Weather System - Environment Variables
# ──────────────────────────────────────────────

# Backend
NODE_ENV=development
PORT=3001
BACKEND_URL=http://localhost:3001

# Database (Supabase PostgreSQL)
# Get this from Supabase > Settings > Database > Connection string (URI)
# Format: postgresql://<user>:<password>@<host>:<port>/<database>?schema=public
DATABASE_URL=postgresql://postgres:your-supabase-password@db.xxxxxxxxxxxxxx.supabase.co:5432/postgres?schema=public

# MQTT
MQTT_BROKER_URL=mqtt://mosquitto:1883
MQTT_CLIENT_ID=weather-backend

# Gemini AI (optional - system works with mock AI without this)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Frontend
VITE_API_URL=http://localhost:3001
VITE_WS_URL=http://localhost:3001

# ESP32 (for simulation mode)
ESP32_DEVICE_ID=station-001

# Weather Simulator
SIMULATOR_INTERVAL=30
SIMULATOR_DEVICE_ID=station-001
SIMULATOR_MQTT_URL=mqtt://mosquitto:1883
